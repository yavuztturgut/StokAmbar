generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  password      String
  username      String    @unique
  accountId     Int?
  account       Account?  @relation("ActiveAccount", fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ownedAccounts Account[] @relation("OwnedAccounts")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([accountId])
  @@index([email])
}

model Account {
  id           Int                @id @default(autoincrement())
  ownerId      Int
  name         String
  email        String             @unique
  phone        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  owner        User               @relation("OwnedAccounts", fields: [ownerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users        User[]             @relation("ActiveAccount")
  ingredients  Ingredient[]
  transactions StockTransaction[]
  logs         ActivityLog[]

  @@index([ownerId])
}

model Ingredient {
  id            Int      @id @default(autoincrement())
  accountId     Int
  name          String
  unit          String
  currentStock  Float    @default(0)
  minStockLevel Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  account       Account  @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transactions  StockTransaction[]

  @@index([accountId])
}

model StockTransaction {
  id           Int        @id @default(autoincrement())
  accountId    Int
  ingredientId Int
  type         String
  quantity     Float
  note         String?
  createdAt    DateTime   @default(now())
  account      Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

model ActivityLog {
  id             Int      @id @default(autoincrement())
  accountId      Int
  action         String
  ingredientId   Int?
  ingredientName String
  quantity       Float?
  details        String?
  createdAt      DateTime @default(now())
  account        Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}
