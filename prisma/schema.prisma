generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  password      String
  username      String   @unique
  accountId     Int
  account       Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([accountId])
  @@index([email])
}

model Account {
  id            Int      @id @default(autoincrement())
  name          String   // Kişi/İşletme adı
  email         String   @unique
  phone         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  users         User[]
  ingredients   Ingredient[]
  transactions  StockTransaction[]
  logs          ActivityLog[]
}

model Ingredient {
  id            Int      @id @default(autoincrement())
  accountId     Int
  name          String
  unit          String   // kg, lt, adet, paket
  currentStock  Float    @default(0)
  minStockLevel Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  account       Account  @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transactions  StockTransaction[]

  @@index([accountId])
}

model StockTransaction {
  id           Int      @id @default(autoincrement())
  accountId    Int
  ingredientId Int
  type         String   // IN, OUT, WASTE
  quantity     Float
  note         String?
  createdAt    DateTime @default(now())
  account      Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

model ActivityLog {
  id             Int      @id @default(autoincrement())
  accountId      Int
  action         String   // CREATE, UPDATE, DELETE, IN, OUT, WASTE
  ingredientId   Int?
  ingredientName String
  quantity       Float?
  details        String?
  createdAt      DateTime @default(now())
  account        Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}
